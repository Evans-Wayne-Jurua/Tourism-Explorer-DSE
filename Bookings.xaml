<Page
    x:Class="Tourism_Explorer_Desktop_Application.Bookings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Tourism_Explorer_Desktop_Application"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/lakeside.jpg"/>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10" Padding="10">
            <TextBlock Text="Book Your Adventure" FontSize="30" FontWeight="ExtraBold"/>
            <TextBlock Text="Full Name" FontSize="15" FontWeight="SemiBold" Margin="0,10,0,10" Foreground="White"/>
            <TextBox PlaceholderText="Enter your name"/>

            <TextBlock Text="Select Destination" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,10"/>
            <ComboBox Width="780">
                <ComboBoxItem>Queen Elizabeth Park</ComboBoxItem>
                <ComboBoxItem>Murchison Falls Park</ComboBoxItem>
                <ComboBoxItem>Lake Victoria</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Travel Date" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,10"/>
            <CalendarDatePicker PlaceholderText="Select a date" x:Name="DatePicker" Width="780"/>

            <TextBlock Text="Number of People" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,10"/>
            <Slider x:Name="PeopleSlider" Minimum="1" Maximum="20" Value="5" TickFrequency="1" Width="780" />

            <TextBlock Text="Special Requirements" FontSize="15" FontWeight="SemiBold" Foreground="White" Margin="0,10,0,10" HorizontalAlignment="Left"/>
            <TextBox PlaceholderText="e.g Dietary needs, photography gear..." Height="100"/>

            <Button Content="Confirm Booking" Foreground="White" Background="SeaGreen" CornerRadius="5" Margin="0,10,0,0"/>


        </StackPanel>

        <StackPanel Grid.Column="1">
            <StackPanel Background="#90FFFFFF" Height="400" Margin="10,100,10,0" CornerRadius="20">
                <TextBlock Text="Booking Summary" FontSize="20" FontWeight="SemiBold" Padding="10"/>
                <TextBlock Text="Destination: Pending Selection" FontStyle="Italic" FontSize="12" Padding="10"/>
                <TextBlock Text="Estimated Price: $0.00" FontSize="10" Padding="10" FontWeight="SemiBold"/>
                <TextBlock Text="All bookings include a licensed guide and park entry fees." FontSize="12" Padding="10"/>
                <Image Source="/Assets/murchisonfalls.jpg" Width="300" Height="200" Margin="10" Stretch="UniformToFill"/>
            </StackPanel>
            
        </StackPanel>

    </Grid>
</Page>
